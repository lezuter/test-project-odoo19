<?xml version="1.0" encoding="UTF-8"?>
<odoo>

<record id="view_product_form" model="ir.ui.view">
    <field name ="name">product.form</field>
    <field name ="model">inventory.product</field>
    <field name ="arch" type="xml">
        <form string="Master Data Products">
            <sheet>
                <group>
                    <field name="produk"/>
                    <field name="sku"/>
                    <field name="kategori"/>
                    <field name="stock"/>
                    <field name="satuan"/>
                    <field name="rak"/>
                    <field name="active"/>
                </group>
            </sheet>
        </form>
    </field>
</record>

<record id="view_product_tree" model="ir.ui.view">
    <field name ="name">product.tree</field>
    <field name ="model">inventory.product</field>
    <field name ="arch" type="xml">
        <list string="Master Data Products">
            <field name="produk"/>
            <field name="sku"/>
            <field name="kategori"/>
            <field name="stock"/>
            <field name="satuan"/>
            <field name="rak"/>
            <field name="active"/>
        </list>
    </field>
</record>

<record id="action_product" model="ir.actions.act_window">
    <field name ="name">Master Data Products</field>
    <field name ="res_model">inventory.product</field>
    <field name ="view_mode">list,form</field>
</record>

<menuitem id="menu_inventory_root" name="Custom Inventory" sequence="10"/>
<menuitem id="menu_inventory_products" name="Master Data products" parent="menu_inventory_root" action="action_product" sequence="10"/>

</odoo>
